                test_image_paths.append(os.path.join(root, file))

    random.seed(42)  
    selected_images = random.sample(test_image_paths, min(args.visualize_samples, len(test_image_paths)))

    for i, image_path in enumerate(selected_images):
        print(f"\n可视化样本 {i + 1}/{len(selected_images)}: {os.path.basename(image_path)}")
        path_parts = image_path.replace('/', '\\').split('\\')
        class_folder = path_parts[-2]
        try:
            true_label = int(class_folder)
        except ValueError:
            true_label = 0  # 默认值
            for class_idx, class_name in enumerate(class_names):
                if class_name == class_folder:
                    true_label = class_idx
                    break

        predicted_class, confidence, heatmap = visualize_gradcam(
            best_model, image_path, class_names, device,
            save_path=f'gradcam_sample_{i + 1}.png'
        )


