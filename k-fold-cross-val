    print(f"\n{'=' * 60}")
    print(f"{'=' * 60}")
    print(f"{[f'{acc * 100:.2f}%' for acc in fold_accuracies]}")
    print(f"{mean_accuracy * 100:.2f}% ± {std_accuracy * 100:.2f}%")
    print(f"(Macro): {mean_precision_macro * 100:.2f}% ± {std_precision_macro * 100:.2f}%")
    print(f"(Macro): {mean_recall_macro * 100:.2f}% ± {std_recall_macro * 100:.2f}%")
    print(f"F1(Macro): {mean_f1_macro * 100:.2f}% ± {std_f1_macro * 100:.2f}%")
    print(f"(Weighted): {mean_precision_weighted * 100:.2f}% ± {std_precision_weighted * 100:.2f}%")
    print(f"(Weighted): {mean_recall_weighted * 100:.2f}% ± {std_recall_weighted * 100:.2f}%")
    print(f"F1(Weighted): {mean_f1_weighted * 100:.2f}% ± {std_f1_weighted * 100:.2f}%")
    print(f"{max(fold_accuracies) * 100:.2f}%")
    print(f" {min(fold_accuracies) * 100:.2f}%")

    best_fold_idx = np.argmax(fold_accuracies)
    best_model = StudentModel(num_classes).to(device)
    best_model.load_state_dict(fold_models[best_fold_idx])

    print(f"\n {best_fold_idx + 1} 折的模型作为最佳模型进行最终测试")

    print(f"\n{'=' * 60}")
    print(f"最佳模型在测试集上的表现")
    print(f"{'=' * 60}")

